{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "contract:generate": "npm run contract:schema && openapi-ts",
    "contract:schema": "uv run python ../scripts/export_openapi.py --output ../contracts/openapi.json",
    "contract:check": "node e2e/support/check-contract.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "node e2e/support/run-e2e.mjs",
    "test:e2e:smoke": "node e2e/support/run-e2e.mjs --grep @smoke",
    "test:e2e:scenario": "node e2e/support/run-e2e.mjs --pass-with-no-tests --grep @scenario",
    "test:e2e:live": "node e2e/support/run-e2e.mjs --live --pass-with-no-tests --grep @live",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.169.1",
    "axios": "^1.16.0",
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "lightweight-charts": "^5.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tslib": "^2.8.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hey-api/openapi-ts": "0.99.0",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.1.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^3.0.0"
  }
}
